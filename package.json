{
  "name": "vas",
  "version": "0.1.0",
  "author": "Nova <babelon1882@gmail.com>",
  "description": "Vas — capture, frame, and share with ease",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test:window": "electron test-window-capture.js",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "sharp": "^0.33.0",
    "tesseract.js": "^4.1.1"
  },
  "build": {
    "appId": "com.tb1982.vas",
    "productName": "Vas",
    "asar": true,
    "compression": "store",
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "img/vas.ico",
      "signAndEditExecutable": false
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "img/vas.png",
      "target": "dmg",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": {
        "teamId": "FILL_IN_AFTER_ENROLLMENT"
      }
    }
  }
}
