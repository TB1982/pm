{
  "name": "vas",
  "version": "0.1.0",
  "author": "Nova <babelon1882@gmail.com>",
  "description": "Vas — capture, frame, and share with ease",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test:window": "electron test-window-capture.js",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "sharp": "^0.33.0",
    "tesseract.js": "^4.1.1"
  },
  "build": {
    "appId": "com.tb1982.vas",
    "productName": "Vas",
    "asar": true,
    "compression": "store",
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns",
      "target": "dmg"
    }
  }
}
