<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron / V8 JIT compilation -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Required for Electron renderer process -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Required for Sharp (native Node.js addon with unsigned dylibs) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Screen Recording: granted at runtime by macOS TCC prompt (no entitlement needed) -->
  <!-- File access: via NSOpenPanel / NSSavePanel, no entitlement needed for user-initiated -->
</dict>
</plist>
