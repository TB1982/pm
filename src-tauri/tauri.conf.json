{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VAS",
  "version": "0.1.0",
  "identifier": "com.tb1982.vas",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8085",
    "beforeDevCommand": "python3 dev-server.py ../src 8085"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "toolbar",
        "url": "http://localhost:8085/index.html",
        "title": "VAS",
        "width": 520,
        "height": 68,
        "minWidth": 520,
        "minHeight": 68,
        "maxHeight": 68,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true,
        "acceptFirstMouse": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
