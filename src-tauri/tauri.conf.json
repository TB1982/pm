{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VAS",
  "version": "0.1.0",
  "identifier": "com.tb1982.vas",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "python3 -m http.server 8080 --directory src"
  },
  "app": {
    "windows": [
      {
        "label": "toolbar",
        "url": "http://localhost:8080/index.html",
        "title": "VAS",
        "width": 520,
        "height": 64,
        "minWidth": 520,
        "minHeight": 64,
        "maxHeight": 64,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
